#!/bin/sh
set -e

case "$1" in
  configure)
    # ── Create system user ────────────────────────────────────────────────────
    if ! id -u watcher >/dev/null 2>&1; then
      adduser --system --group --no-create-home \
              --home /var/lib/watcher \
              --shell /usr/sbin/nologin \
              --gecos "Watcher IDS" \
              watcher
      echo "Created system user: watcher"
    fi

    # ── Add watcher to suricata group for eve.json read access ────────────────
    if getent group suricata >/dev/null 2>&1; then
      usermod -aG suricata watcher
      echo "Added watcher to suricata group (eve.json access granted)."
    else
      echo "Note: suricata group not found — install Suricata first, then run:"
      echo "      usermod -aG suricata watcher && systemctl restart watcher"
    fi

    # ── Directories and ownership ─────────────────────────────────────────────
    chown -R root:watcher /opt/watcher
    chmod -R o-rwx /opt/watcher
    chmod 755 /opt/watcher

    chown watcher:watcher /var/lib/watcher
    chmod 750 /var/lib/watcher

    chown root:watcher /etc/watcher
    chmod 750 /etc/watcher
    if [ -f /etc/watcher/watcher.conf ]; then
      chown root:watcher /etc/watcher/watcher.conf
      chmod 640 /etc/watcher/watcher.conf
    fi

    # ── Bootstrap admin credentials (first install only) ─────────────────────
    CONFIG_DB="/var/lib/watcher/config.db"

    ADMIN_PW=$(python3 - "$CONFIG_DB" <<'PYEOF'
import sys, sqlite3, secrets, hashlib, time

db_path = sys.argv[1]
con = sqlite3.connect(db_path)

con.executescript("""
    CREATE TABLE IF NOT EXISTS sessions (
        token      TEXT PRIMARY KEY,
        created_at REAL NOT NULL,
        expires_at REAL NOT NULL,
        username   TEXT DEFAULT '',
        role       TEXT DEFAULT 'admin'
    );
    CREATE TABLE IF NOT EXISTS users (
        id         INTEGER PRIMARY KEY AUTOINCREMENT,
        username   TEXT    NOT NULL UNIQUE COLLATE NOCASE,
        pw_hash    TEXT    NOT NULL,
        role       TEXT    NOT NULL DEFAULT 'analyst',
        enabled    INTEGER NOT NULL DEFAULT 1,
        created_at REAL    NOT NULL,
        last_login REAL
    );
""")
con.commit()

count = con.execute("SELECT COUNT(*) FROM users").fetchone()[0]
if count > 0:
    print("")
    con.close()
    sys.exit(0)

pw   = secrets.token_urlsafe(14)
salt = secrets.token_hex(16)
h    = hashlib.pbkdf2_hmac("sha256", pw.encode(), salt.encode(), 260_000)
pw_hash = f"{salt}${h.hex()}"

con.execute(
    "INSERT INTO users (username, pw_hash, role, enabled, created_at) VALUES (?,?,?,1,?)",
    ("admin", pw_hash, "admin", time.time()),
)
con.commit()
con.close()
print(pw)
PYEOF
    )

    chown watcher:watcher "$CONFIG_DB" 2>/dev/null || true
    chmod 640 "$CONFIG_DB"             2>/dev/null || true

    # ── Systemd ───────────────────────────────────────────────────────────────
    systemctl daemon-reload 2>/dev/null || true
    systemctl enable watcher.service   2>/dev/null || true

    if systemctl is-active --quiet watcher.service 2>/dev/null; then
      systemctl restart watcher.service
    else
      systemctl start watcher.service 2>/dev/null || true
    fi

    # ── Install banner ────────────────────────────────────────────────────────
    echo ""
    echo "┌─────────────────────────────────────────────────────────┐"
    echo "│  Watcher IDS v1.7.3 installed successfully              │"
    echo "│                                                         │"
    echo "│  Dashboard  →  http://localhost:8765/                   │"
    echo "│  Logs       →  journalctl -u watcher -f                 │"
    echo "│  Status     →  systemctl status watcher                 │"
    echo "│  Config     →  /etc/watcher/watcher.conf                │"
    echo "│                                                         │"

    if [ -n "$ADMIN_PW" ]; then
      echo "│  ┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄  │"
      echo "│  First-run credentials                                  │"
      echo "│    Username  →  admin                                   │"
      printf "│    Password  →  %-38s │\n" "$ADMIN_PW"
      echo "│    Change:      Settings → Users → Edit                 │"
      echo "│  ┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄  │"
    fi

    echo "│                                                         │"
    echo "│  What's new in v1.7.3:                                  │"
    echo "│    • Fix: replay no longer fires live webhooks          │"
    echo "│    • Fix: alert ID collision under high traffic         │"
    echo "│      (entropy suffix — no more silent drops)            │"
    echo "│    • Perf: webhook config cached 30 s — no per-alert DB │"
    echo "│    • Perf: webhook retries non-blocking, no stalls      │"
    echo "│                                                         │"
    echo "│  v1.7.2:                                                │"
    echo "│    • Fix: '0 found in DB' badge rendered as a huge     │"
    echo "│      200 px box (CSS class-name collision resolved)     │"
    echo "│    • All search-status badges now identical in size:    │"
    echo "│      Searching… / N found in DB / 0 found in DB        │"
    echo "│                                                         │"
    echo "│  v1.7.1:                                                │"
    echo "│    • Full-database alert search (SID, IP, Signature)    │"
    echo "│    • Search queries the whole DB — not just loaded rows │"
    echo "│    • Debounced search (400 ms) with 'X found in DB'     │"
    echo "│    • Load more support for search result pagination     │"
    echo "│    • ✕ clear button in search input                     │"
    echo "│    • dst_ip index for faster destination searches       │"
    echo "│                                                         │"
    echo "│  v1.7.0:                                                │"
    echo "│    • AI Explain — executive summaries on every alert    │"
    echo "│      DeepSeek / OpenAI / Claude / NVIDIA NIM            │"
    echo "│    • Auto-generate summary on each new unique SID       │"
    echo "│    • Settings → AI Explain: enable, pick provider,      │"
    echo "│      manage API keys per-provider via UI or watcher.conf│"
    echo "│    • Fix: webhook Test now respects Allow Local IPs     │"
    echo "│    • Fix: stale blocked-error cleared when local IPs on │"
    echo "│    • Fully air-gapped — zero external font/CDN deps     │"
    echo "└─────────────────────────────────────────────────────────┘"
    echo ""
    ;;
esac

exit 0
